expression Stg_Shipments = ```
		let
		    // 1. Carga del archivo CSV con tu ruta exacta
		    Origen = Csv.Document(File.Contents("C:\Users\martinybauti\Downloads\logistics_shipments_dataset.csv"), [Delimiter=",", Columns=11, Encoding=65001, QuoteStyle=QuoteStyle.None]),
		    
		    // 2. Promover cabeceras
		    CabecerasPromovidas = Table.PromoteHeaders(Origen, [PromoteAllScalars=true]),
		    
		    // 3. Tipado inicial de datos (Usamos "Shipment_ID" directamente aquí sin renombrar)
		    TiposCambiados = Table.TransformColumnTypes(CabecerasPromovidas, {
		        {"Shipment_ID", type text}, {"Origin_Warehouse", type text}, {"Destination", type text}, 
		        {"Carrier", type text}, {"Shipment_Date", type date}, {"Delivery_Date", type date}, 
		        {"Weight_kg", type number}, {"Cost", type number}, {"Status", type text}, 
		        {"Distance_miles", Int64.Type}, {"Transit_Days", Int64.Type}
		    }),
		
		    // 4. Corregir anomalía de fechas
		    CorregirFechas = Table.AddColumn(TiposCambiados, "Delivery_Date_Clean", each 
		        if [Delivery_Date] < [Shipment_Date] 
		        then Date.AddDays([Shipment_Date], [Transit_Days]) 
		        else [Delivery_Date], 
		        type date
		    ),
		
		    // 5. Eliminar columna vieja de fecha y dejar la corregida
		    ColumnaRemovida = Table.RemoveColumns(CorregirFechas, {"Delivery_Date"}),
		    FinalClean = Table.RenameColumns(ColumnaRemovida, {{"Delivery_Date_Clean", "Delivery_Date"}})
		in
		    FinalClean
		```
	lineageTag: 0d83b2ed-2eb7-45df-9c60-d93d47159903

