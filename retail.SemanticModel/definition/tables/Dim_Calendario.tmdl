	column AñoMes_Key
		dataType: int64
		formatString: 0
		lineageTag: ffeeb2fe-bf5e-4acf-a42d-5a3c5b3095aa
		summarizeBy: count
		sourceColumn: AñoMes_Key

		annotation SummarizationSetBy = Automatic

	partition Dim_Calendario = m
		mode: import
		source = ```
				let
				    // 1. Apuntamos directamente a la tabla de staging limpia para evitar dependencias circulares
				    Fechas = Stg_Shipments[Shipment_Date],
				    FechaMinima = List.Min(Fechas),
				    FechaMaxima = List.Max(Fechas),
				    
				    // 2. Calculamos la cantidad de días entre ambas fechas
				    CantidadDias = Duration.Days(Duration.From(FechaMaxima - FechaMinima)) + 1,
				    
				    // 3. Generamos la lista de fechas consecutivas
				    ListaFechas = List.Dates(FechaMinima, CantidadDias, #duration(1, 0, 0, 0)),
				    
				    // 4. Convertimos la lista en una tabla
				    TablaBase = Table.FromList(ListaFechas, Splitter.SplitByNothing(), null, null, ExtraValues.Error),
				    ColumnasRenombradas = Table.RenameColumns(TablaBase, {{"Column1", "Date"}}),
				    TipoFecha = Table.TransformColumnTypes(ColumnasRenombradas, {{"Date", type date}}),
				    
				    // 5. Agregamos las columnas de atributos temporales
				    AñoAgregado = Table.AddColumn(TipoFecha, "Año", each Date.Year([Date]), Int64.Type),
				    MesNumeroAgregado = Table.AddColumn(AñoAgregado, "Mes_Nro", each Date.Month([Date]), Int64.Type),
				    MesNombreAgregado = Table.AddColumn(MesNumeroAgregado, "Mes_Nombre", each Text.Proper(Date.MonthName([Date])), type text),
				    TrimestreAgregado = Table.AddColumn(MesNombreAgregado, "Trimestre", each "T" & Text.From(Date.QuarterOfYear([Date])), type text),
				    DiaSemanaAgregado = Table.AddColumn(TrimestreAgregado, "Dia_Semana", each Date.DayOfWeek([Date]) + 1, Int64.Type),
				    NombreDiaAgregado = Table.AddColumn(DiaSemanaAgregado, "Día_Nombre", each Text.Proper(Date.DayOfWeekName([Date])), type text),
				    
				    // 6. Columna de orden para ordenar cronológicamente
				    AñoMesInt = Table.AddColumn(NombreDiaAgregado, "AñoMes_Key", each Date.Year([Date]) * 100 + Date.Month([Date]), Int64.Type)
				in
				    AñoMesInt
				```

	annotation PBI_NavigationStepName = Navegación

	annotation PBI_ResultType = Table

