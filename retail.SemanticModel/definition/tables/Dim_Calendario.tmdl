table Dim_Calendario
	lineageTag: 140bd3f7-5a92-4362-b372-aff46de62135

	measure 'Total Envíos' = COUNTROWS(Fact_Shipments)
		formatString: 0
		lineageTag: eb84083d-0e54-4f6e-bb3c-5923e3164cb3

	measure 'Costo Total' = SUM(Fact_Shipments[Cost])
		lineageTag: 137503c6-5812-4b54-a19b-5c5633966f90

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Costo Promedio x Envío' = DIVIDE([Costo Total], [Total Envíos], 0)
		lineageTag: 4703811a-6ace-4c75-afd9-e89b0e43ac07

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Días Tránsito Promedio' = AVERAGE(Fact_Shipments[Transit_Days])
		lineageTag: e5f7cc0f-d231-4b6b-a773-ea1881d1a8d9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '% Entregas Exitosas' = DIVIDE(CALCULATE([Total Envíos], Fact_Shipments[Status] = "Delivered"), [Total Envíos], 0)
		lineageTag: ef5adcea-23bb-474c-be5d-e972b6d2329e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

