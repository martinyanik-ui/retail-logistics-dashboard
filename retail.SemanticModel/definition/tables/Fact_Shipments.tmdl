	partition Fact_Shipments = m
		mode: import
		source = ```
				let
				    Origen = Stg_Shipments,
				    
				    // Cruces de datos para reemplazar texto por ID numérico
				    MergeWarehouse = Table.NestedJoin(Origen, {"Origin_Warehouse"}, Dim_Warehouse, {"Origin_Warehouse"}, "Dim_Warehouse", JoinKind.LeftOuter),
				    ExpandWarehouse = Table.ExpandTableColumn(MergeWarehouse, "Dim_Warehouse", {"Warehouse_ID"}, {"Warehouse_ID"}),
				    
				    MergeDestino = Table.NestedJoin(ExpandWarehouse, {"Destination"}, Dim_Destinos, {"Destination"}, "Dim_Destinos", JoinKind.LeftOuter),
				    ExpandDestino = Table.ExpandTableColumn(MergeDestino, "Dim_Destinos", {"Destination_ID"}, {"Destination_ID"}),
				    
				    MergeCarrier = Table.NestedJoin(ExpandDestino, {"Carrier"}, Dim_Carriers, {"Carrier"}, "Dim_Carriers", JoinKind.LeftOuter),
				    ExpandCarrier = Table.ExpandTableColumn(MergeCarrier, "Dim_Carriers", {"Carrier_ID"}, {"Carrier_ID"}),
				    
				    // Limpieza de columnas de texto originales
				    ColumnasQuitadas = Table.RemoveColumns(ExpandCarrier, {"Origin_Warehouse", "Destination", "Carrier"}),
				    
				    OrdenFinal = Table.ReorderColumns(ColumnasQuitadas, {
				        "Shipment_ID", "Warehouse_ID", "Destination_ID", "Carrier_ID", 
				        "Shipment_Date", "Delivery_Date", "Weight_kg", "Cost", "Status", "Distance_miles", "Transit_Days"
				    })
				in
				    OrdenFinal
				```

	annotation PBI_NavigationStepName = Navegación

	annotation PBI_ResultType = Table

